# ============================================
# E-KALDIK PRODUCTION CONFIGURATION
# ============================================
# Copy this file to .env and update values
# Site: https://simkur.smkpgriblora.sch.id

# APPLICATION
APP_NAME="e-KALDIK"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://simkur.smkpgriblora.sch.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# LOGGING
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# DATABASE (MySQL Production)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simkur_ekaldik
DB_USERNAME=simkur_user
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# SESSION CONFIGURATION (CRITICAL FOR LOGIN)
# Use 'file' driver for production - more reliable than database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
# HTTPS settings
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# BROADCASTING
BROADCAST_CONNECTION=log

# FILESYSTEM
FILESYSTEM_DISK=local

# QUEUE
QUEUE_CONNECTION=database

# CACHE
CACHE_STORE=file
CACHE_PREFIX=ekaldik

# MAIL (Optional - configure if needed)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@smkpgriblora.sch.id"
MAIL_FROM_NAME="${APP_NAME}"

# VITE
VITE_APP_NAME="${APP_NAME}"
